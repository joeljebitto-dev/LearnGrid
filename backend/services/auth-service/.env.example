DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=insecure-local-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
SERVICE_PORT=8001
PORT=8001
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT_SECONDS=60
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=auth-service
DATABASE_URL=postgresql://learngrid:learngrid@localhost:5432/auth_db
REDIS_URL=redis://localhost:6379/0
REDIS_SENTINEL_URLS=
REDIS_SENTINEL_MASTER_NAME=mymaster
REDIS_SENTINEL_PASSWORD=
REDIS_PASSWORD=
REDIS_ENV=local
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=0.2
REDIS_SOCKET_TIMEOUT_SECONDS=0.2
REDIS_LOCK_TTL_SECONDS=30
AUTH_ACCESS_TOKEN_LIFETIME_SECONDS=300
AUTH_REFRESH_TOKEN_LIFETIME_SECONDS=604800
AUTH_JWT_ISSUER=learngrid-auth-service
AUTH_JWT_SIGNING_KEY=insecure-local-auth-service-change-me-32bytes
AUTH_TOKEN_HASH_KEY=insecure-local-auth-service-change-me-32bytes
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PERMISSION_CACHE_TTL_SECONDS=300
AUTH_LOGIN_RATE_LIMIT_COUNT=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_PASSWORD_RESET_RATE_LIMIT_COUNT=3
AUTH_PASSWORD_RESET_TTL_SECONDS=900
AUTH_PASSWORD_RESET_DEBUG_RETURN_TOKEN=false
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OIDC_ENABLED=false
AUTH_OIDC_PROVIDER_LABEL=SSO
AUTH_OIDC_ISSUER_URL=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
AUTH_OIDC_REDIRECT_URI=http://127.0.0.1:5173/auth/oidc/callback
AUTH_OIDC_SCOPES=openid email profile
AUTH_OIDC_REQUIRE_EMAIL_VERIFIED=true
AUTH_OIDC_STATE_TTL_SECONDS=300
AUTH_OIDC_JWKS_CACHE_TTL_SECONDS=3600
