DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=insecure-local-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
SERVICE_PORT=8009
PORT=8009
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT_SECONDS=60
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=notification-service
DATABASE_URL=postgresql://learngrid:learngrid@localhost:5432/notification_db
REDIS_URL=redis://localhost:6379/0
AUTH_SERVICE_BASE_URL=http://127.0.0.1:8001
USER_SERVICE_BASE_URL=http://127.0.0.1:8002
AUTH_JWT_SIGNING_KEY=insecure-local-auth-service-change-me-32bytes
AUTH_JWT_ISSUER=learngrid-auth-service
AUTH_JWT_ALGORITHM=HS256
