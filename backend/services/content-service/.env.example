DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=insecure-local-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
SERVICE_PORT=8004
DATABASE_URL=postgresql://learngrid:learngrid@localhost:5432/content_db
REDIS_URL=redis://localhost:6379/0
CONTENT_STORAGE_PROVIDER=minio
CONTENT_STORAGE_BUCKET=learngrid-content
CONTENT_MINIO_ENDPOINT_URL=http://127.0.0.1:9000
CONTENT_MINIO_ACCESS_KEY=learngrid
CONTENT_MINIO_SECRET_KEY=learngrid-minio-secret
CONTENT_MINIO_SECURE=false
CONTENT_PRESIGNED_UPLOAD_TTL_SECONDS=900
CONTENT_PRESIGNED_DOWNLOAD_TTL_SECONDS=300
AUTH_SERVICE_BASE_URL=http://127.0.0.1:8001
AUTH_JWT_SIGNING_KEY=insecure-local-auth-service-change-me-32bytes
AUTH_JWT_ISSUER=learngrid-auth-service
AUTH_JWT_ALGORITHM=HS256
